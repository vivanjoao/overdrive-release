<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/dashboardFragment">

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.overdrive.app.ui.fragment.DashboardFragment"
        android:label="@string/nav_page_dashboard"
        tools:layout="@layout/fragment_dashboard" />

    <fragment
        android:id="@+id/daemonsFragment"
        android:name="com.overdrive.app.ui.fragment.DaemonsFragment"
        android:label="@string/nav_page_daemons"
        tools:layout="@layout/fragment_daemons" />

    <fragment
        android:id="@+id/recordingFragment"
        android:name="com.overdrive.app.ui.fragment.WebViewFragment"
        android:label="@string/nav_page_recording"
        tools:layout="@layout/fragment_webview">
        <argument
            android:name="page_path"
            app:argType="string"
            android:defaultValue="/recording" />
    </fragment>

    <fragment
        android:id="@+id/adbConsoleFragment"
        android:name="com.overdrive.app.ui.fragment.AdbConsoleFragment"
        android:label="@string/nav_page_adb_console"
        tools:layout="@layout/fragment_adb_console" />

    <fragment
        android:id="@+id/sentryConfigFragment"
        android:name="com.overdrive.app.ui.fragment.WebViewFragment"
        android:label="@string/nav_page_surveillance"
        tools:layout="@layout/fragment_webview">
        <argument
            android:name="page_path"
            app:argType="string"
            android:defaultValue="/surveillance" />
    </fragment>

    <fragment
        android:id="@+id/eventsFragment"
        android:name="com.overdrive.app.ui.fragment.RecordingLibraryFragment"
        android:label="@string/nav_page_events"
        tools:layout="@layout/fragment_recording_library" />

    <fragment
        android:id="@+id/videoPlayerFragment"
        android:name="com.overdrive.app.ui.fragment.VideoPlayerFragment"
        android:label="@string/nav_page_video_player"
        tools:layout="@layout/fragment_video_player">
        <argument
            android:name="video_path"
            app:argType="string" />
        <argument
            android:name="video_title"
            app:argType="string"
            android:defaultValue="" />
    </fragment>

    <!-- Global action so any fragment can navigate to video player -->
    <action
        android:id="@+id/action_global_videoPlayer"
        app:destination="@id/videoPlayerFragment" />

    <fragment
        android:id="@+id/telegramSettingsFragment"
        android:name="com.overdrive.app.ui.fragment.TelegramSettingsFragment"
        android:label="@string/nav_page_telegram"
        tools:layout="@layout/fragment_telegram_settings" />

    <fragment
        android:id="@+id/abrpSettingsFragment"
        android:name="com.overdrive.app.ui.fragment.WebViewFragment"
        android:label="@string/nav_page_abrp"
        tools:layout="@layout/fragment_webview">
        <argument
            android:name="page_path"
            app:argType="string"
            android:defaultValue="/abrp" />
    </fragment>

    <fragment
        android:id="@+id/mqttFragment"
        android:name="com.overdrive.app.ui.fragment.WebViewFragment"
        android:label="@string/nav_page_mqtt"
        tools:layout="@layout/fragment_webview">
        <argument
            android:name="page_path"
            app:argType="string"
            android:defaultValue="/mqtt" />
    </fragment>

    <fragment
        android:id="@+id/tripsFragment"
        android:name="com.overdrive.app.ui.fragment.WebViewFragment"
        android:label="@string/nav_page_trips"
        tools:layout="@layout/fragment_webview">
        <argument
            android:name="page_path"
            app:argType="string"
            android:defaultValue="/trips" />
    </fragment>

    <fragment
        android:id="@+id/vehicleControlFragment"
        android:name="com.overdrive.app.ui.fragment.WebViewFragment"
        android:label="@string/nav_page_vehicle_control"
        tools:layout="@layout/fragment_webview">
        <argument
            android:name="page_path"
            app:argType="string"
            android:defaultValue="/vehicle-control" />
    </fragment>

</navigation>
