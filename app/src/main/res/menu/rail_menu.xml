<?xml version="1.0" encoding="utf-8"?>
<!--
  Top-level destinations on the navigation rail.
  Order matches the user's mental model: at-a-glance → recordings → vehicle/trips → integrations → diagnostics → settings.
  Settings sits last because it's the "set & forget" surface.
-->
<menu xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:id="@+id/dashboardFragment"
        android:icon="@drawable/ic_dashboard"
        android:title="@string/rail_dashboard" />
    <item
        android:id="@+id/liveViewFragment"
        android:icon="@drawable/ic_live"
        android:title="@string/rail_live" />
    <item
        android:id="@+id/recordingsFragment"
        android:icon="@drawable/ic_recording"
        android:title="@string/rail_recordings" />
    <item
        android:id="@+id/vehicleControlFragment"
        android:icon="@drawable/ic_vehicle_control"
        android:title="@string/rail_vehicle" />
    <item
        android:id="@+id/tripsFragment"
        android:icon="@drawable/ic_trips"
        android:title="@string/rail_trips" />
    <item
        android:id="@+id/integrationsFragment"
        android:icon="@drawable/ic_integrations"
        android:title="@string/rail_integrations" />
    <item
        android:id="@+id/roadSenseFragment"
        android:icon="@drawable/ic_roadsense"
        android:title="@string/rail_roadsense" />
    <item
        android:id="@+id/diagnosticsFragment"
        android:icon="@drawable/ic_diagnostics"
        android:title="@string/rail_diagnostics" />
    <item
        android:id="@+id/settingsFragment"
        android:icon="@drawable/ic_settings"
        android:title="@string/rail_settings" />
    <!-- About lives on the rail too so users can reach it without
         hunting inside Settings. SettingsAboutFragment hosts version,
         license, source link, support links + Check for Updates. -->
    <item
        android:id="@+id/settingsAboutFragment"
        android:icon="@drawable/ic_update"
        android:title="@string/settings_section_about" />
</menu>
