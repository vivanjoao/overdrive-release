<?xml version="1.0" encoding="utf-8"?>
<!-- Quick-toggle chip background for the audio/visual segment buttons. Selected
     state = filled accent; unselected = faint outline. State-driven so the
     overlay can show which warn modes are active at a glance (R-OVL-3). -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="#3357C7FF" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#8057C7FF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#14FFFFFF" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#1FFFFFFF" />
        </shape>
    </item>
</selector>
