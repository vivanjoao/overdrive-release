<?xml version="1.0" encoding="utf-8"?>
<!-- Calibration-Mode confirm sub-panel — a slightly raised inset surface with an
     amber attention edge so the "was this a hazard?" prompt clearly stands apart
     from the telemetry above it without shouting. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="270"
        android:startColor="#1FF2A33D"
        android:endColor="#14000000" />
    <corners android:radius="16dp" />
    <stroke android:width="1dp" android:color="#4DF2A33D" />
</shape>
