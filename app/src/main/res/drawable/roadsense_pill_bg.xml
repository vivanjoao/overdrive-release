<?xml version="1.0" encoding="utf-8"?>
<!-- Collapsed RoadSense pill: glassy dark capsule. Mirrors the cockpit-instrument
     language of the status overlay but rounder/softer (a sensing aid, not an alarm). -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#E60E1416" />
    <corners android:radius="22dp" />
    <stroke
        android:width="1dp"
        android:color="#1FFFFFFF" />
</shape>
