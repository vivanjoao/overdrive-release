<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Command Input Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="@color/bg_surface"
        app:cardCornerRadius="12dp"
        app:strokeColor="@color/card_border"
        app:strokeWidth="1dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/adb_prompt"
                android:textColor="@color/brand_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCommand"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:fontFamily="monospace"
                android:hint="@string/adb_command_hint"
                android:imeOptions="actionSend"
                android:inputType="text"
                android:singleLine="true"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExecute"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:text="@string/action_run"
                app:backgroundTint="@color/brand_primary"
                android:textColor="@color/bg_base"
                app:cornerRadius="8dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Preset Commands -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="@string/adb_preset_commands_header"
        android:textColor="@color/text_muted"
        android:textSize="11sp"
        android:letterSpacing="0.1" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerPresets"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:clipToPadding="false" />

    <!-- Output Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="@string/adb_output_header"
        android:textColor="@color/text_muted"
        android:textSize="11sp"
        android:letterSpacing="0.1" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:cardBackgroundColor="@color/bg_surface"
        app:cardCornerRadius="12dp"
        app:strokeColor="@color/card_border"
        app:strokeWidth="1dp"
        app:cardElevation="0dp">

        <ScrollView
            android:id="@+id/scrollOutput"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/tvOutput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:padding="16dp"
                android:text="@string/adb_output_ready"
                android:textColor="@color/brand_primary"
                android:textIsSelectable="true"
                android:textSize="12sp" />

        </ScrollView>

    </com.google.android.material.card.MaterialCardView>

    <!-- Clear Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnClearOutput"
        style="@style/Widget.Overdrive.Button.Text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="8dp"
        android:text="@string/action_clear_output" />

</LinearLayout>
