<?xml version="1.0" encoding="utf-8"?>
<!--
  Recording grid tile — designed for a 2-column grid (item 7 SOTA pattern,
  Google-Photos / Eufy-style). Aspect 16:10 with metadata layered on top of
  the thumbnail. Severity tint on top corner; duration on bottom-right; actor
  pills on bottom-left.
-->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardBackgroundColor="@color/bg_surface"
    app:cardCornerRadius="14dp"
    app:strokeColor="@color/card_border"
    app:strokeWidth="1dp"
    app:cardElevation="0dp"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Thumbnail surface with overlays.
             Aspect handled by fixed height (LinearLayout parent ignores
             ConstraintLayout dimensionRatio attrs). 160dp pairs nicely with the
             ~half-screen width a 2-col grid yields on phones. -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="160dp">

            <ImageView
                android:id="@+id/ivThumbnail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:adjustViewBounds="true"
                android:background="@color/surface_variant"
                android:contentDescription="@string/cd_video_thumbnail"
                android:scaleType="centerCrop" />

            <!-- Severity stripe — solid bar across the top edge, set programmatically. -->
            <View
                android:id="@+id/severityStripe"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_gravity="top"
                android:visibility="gone"
                android:background="@color/status_warning" />

            <!-- Top-right severity badge -->
            <TextView
                android:id="@+id/tvSeverity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="6dp"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:textColor="@android:color/white"
                android:textSize="9sp"
                android:fontFamily="sans-serif-medium"
                android:visibility="gone"
                tools:text="ALERT" />

            <!-- Top-left camera/type chip -->
            <TextView
                android:id="@+id/tvCameraId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="6dp"
                android:background="@drawable/calendar_day_bg_selected"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:textColor="@color/bg_base"
                android:textSize="9sp"
                android:fontFamily="sans-serif-medium"
                tools:text="C0" />

            <!-- Bottom-right duration -->
            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="6dp"
                android:background="#99000000"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                tools:text="0:42" />

            <!-- Bottom-left actor summary (overlay pills) -->
            <TextView
                android:id="@+id/tvActorSummary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_margin="6dp"
                android:background="#99000000"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:visibility="gone"
                android:singleLine="true"
                android:ellipsize="end"
                android:maxWidth="220dp"
                tools:text="👤 1 · close" />

            <!-- Selection checkbox: bottom-right when in select mode (overrides duration) -->
            <CheckBox
                android:id="@+id/cbSelect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="2dp"
                android:visibility="gone"
                android:buttonTint="@color/brand_primary" />

            <!-- Big play affordance on tap (centred, slightly transparent) -->
            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_play_circle"
                android:alpha="0.85"
                android:contentDescription="@string/cd_play" />

        </FrameLayout>

        <!-- Metadata footer (compact: time · size · filename) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="10dp"
            android:paddingVertical="8dp">

            <TextView
                android:id="@+id/tvFilename"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:singleLine="true"
                android:ellipsize="middle"
                tools:text="event_20260514_223124.mp4" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <TextView
                    android:id="@+id/tvRecordingTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    tools:text="22:31" />

                <View
                    android:layout_width="3dp"
                    android:layout_height="3dp"
                    android:layout_marginHorizontal="6dp"
                    android:background="@drawable/recording_indicator_dot" />

                <TextView
                    android:id="@+id/tvSize"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:singleLine="true"
                    tools:text="125 MB" />

                <ImageButton
                    android:id="@+id/btnDelete"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/cd_delete"
                    android:src="@drawable/ic_delete"
                    app:tint="@color/text_muted" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
