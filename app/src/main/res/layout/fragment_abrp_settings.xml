<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ABRP Token Configuration -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/bg_surface"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/card_border"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/abrp_token_config_title"
                    android:textAppearance="@style/TextAppearance.Overdrive.Subtitle"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/abrp_token_hint"
                    app:endIconMode="password_toggle"
                    app:boxBackgroundColor="@color/bg_elevated"
                    app:boxStrokeColor="@color/card_border"
                    app:hintTextColor="@color/text_muted"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAbrpToken"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:maxLines="1"
                        android:textColor="@color/text_primary" />

                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveTest"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/abrp_save_test"
                        app:backgroundTint="@color/brand_primary"
                        android:textColor="@color/bg_base"
                        app:cornerRadius="12dp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tvTokenStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/abrp_not_configured"
                        android:textColor="@color/text_muted" />

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Service Control -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/bg_surface"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/card_border"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/abrp_service_control_title"
                    android:textAppearance="@style/TextAppearance.Overdrive.Subtitle"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchAbrpEnabled"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/abrp_enable_telemetry"
                    android:textColor="@color/text_primary"
                    android:paddingVertical="8dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginVertical="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/abrp_connection_status_label"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvConnectionStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/abrp_disconnected"
                        android:textColor="@color/text_muted" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/abrp_last_upload_label"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvLastUpload"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/abrp_last_upload_never"
                        android:textColor="@color/text_muted" />

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Telemetry Preview -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/bg_surface"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/card_border"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/abrp_telemetry_preview_title"
                    android:textAppearance="@style/TextAppearance.Overdrive.Subtitle"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/tvTelemetryPreview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/abrp_no_telemetry"
                    android:textColor="@color/text_muted"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:padding="8dp"
                    android:background="@color/bg_elevated" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Token Management -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/bg_surface"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/card_border"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/abrp_token_management_title"
                    android:textAppearance="@style/TextAppearance.Overdrive.Subtitle"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDeleteToken"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/abrp_delete_token"
                    style="@style/Widget.Overdrive.Button.Outlined"
                    app:strokeColor="@color/status_danger"
                    android:textColor="@color/status_danger" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
