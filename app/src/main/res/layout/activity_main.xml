<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_base">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/legacy_app_title"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/brand_primary"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <!-- Camera Selection Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_surface"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/card_border"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/legacy_camera_selection"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <ToggleButton
                        android:id="@+id/btnCam1"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="48dp"
                        android:layout_margin="4dp"
                        android:textOn="@string/legacy_cam1_on"
                        android:textOff="@string/legacy_cam1_off"
                        android:textSize="12sp"
                        android:textColor="@color/text_primary"
                        android:background="@drawable/camera_button_bg"/>

                    <ToggleButton
                        android:id="@+id/btnCam2"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="48dp"
                        android:layout_margin="4dp"
                        android:textOn="@string/legacy_cam2_on"
                        android:textOff="@string/legacy_cam2_off"
                        android:textSize="12sp"
                        android:textColor="@color/text_primary"
                        android:background="@drawable/camera_button_bg"/>

                    <ToggleButton
                        android:id="@+id/btnCam3"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="48dp"
                        android:layout_margin="4dp"
                        android:textOn="@string/legacy_cam3_on"
                        android:textOff="@string/legacy_cam3_off"
                        android:textSize="12sp"
                        android:textColor="@color/text_primary"
                        android:background="@drawable/camera_button_bg"/>

                    <ToggleButton
                        android:id="@+id/btnCam4"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="48dp"
                        android:layout_margin="4dp"
                        android:textOn="@string/legacy_cam4_on"
                        android:textOff="@string/legacy_cam4_off"
                        android:textSize="12sp"
                        android:textColor="@color/text_primary"
                        android:background="@drawable/camera_button_bg"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Recording Controls Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_surface"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/card_border"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStartRecording"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:text="@string/legacy_start_rec"
                    android:textSize="12sp"
                    app:backgroundTint="@color/status_success"
                    android:textColor="@color/bg_base"
                    app:cornerRadius="12dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStopRecording"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:text="@string/legacy_stop_rec"
                    android:textSize="12sp"
                    app:backgroundTint="@color/status_danger"
                    android:textColor="@color/white"
                    android:enabled="false"
                    app:cornerRadius="12dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Status Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_surface"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/card_border"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/legacy_status_label"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/legacy_status_idle"
                    android:textSize="13sp"
                    android:textColor="@color/status_warning"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tvStreamStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/legacy_stream_starting"
                    android:textSize="13sp"
                    android:textColor="@color/brand_secondary"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tvDeviceId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/legacy_id_loading"
                    android:textSize="13sp"
                    android:textColor="@color/brand_secondary"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tvTunnelUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/legacy_tunnel_not_connected"
                    android:textSize="12sp"
                    android:textColor="@color/brand_primary"
                    android:textIsSelectable="true"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tvBatteryVoltage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/legacy_battery_dashes"
                    android:textSize="13sp"
                    android:textColor="@color/status_success"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Control Buttons Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_surface"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/card_border"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/legacy_services"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp"/>

                <!-- Row 1: Tunnel + Proxy -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStartTunnel"
                        style="@style/Widget.Overdrive.Button.Outlined"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="40dp"
                        android:layout_marginEnd="4dp"
                        android:text="@string/legacy_tunnel"
                        android:textSize="10sp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStopTunnel"
                        style="@style/Widget.Overdrive.Button.Outlined"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:text="@string/legacy_stop_tun"
                        android:textSize="10sp"
                        android:enabled="false"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStartProxy"
                        style="@style/Widget.Overdrive.Button.Outlined"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="40dp"
                        android:layout_marginEnd="4dp"
                        android:text="@string/legacy_proxy"
                        android:textSize="10sp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStopProxy"
                        style="@style/Widget.Overdrive.Button.Outlined"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="40dp"
                        android:text="@string/legacy_stop_prx"
                        android:textSize="10sp"/>
                </LinearLayout>

                <!-- Row 2: Sentry + Camera Daemon -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStartSentryDaemon"
                        style="@style/Widget.Overdrive.Button.Outlined"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="40dp"
                        android:layout_marginEnd="4dp"
                        android:text="@string/legacy_sentry"
                        android:textSize="10sp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStopSentryDaemon"
                        style="@style/Widget.Overdrive.Button.Outlined"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:text="@string/legacy_stop_snt"
                        android:textSize="10sp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStartCamDaemon"
                        style="@style/Widget.Overdrive.Button.Outlined"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="40dp"
                        android:layout_marginEnd="4dp"
                        android:text="@string/legacy_cam"
                        android:textSize="10sp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStopCamDaemon"
                        style="@style/Widget.Overdrive.Button.Outlined"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="40dp"
                        android:text="@string/legacy_stop_cam"
                        android:textSize="10sp"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Toggle Buttons Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_surface"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/card_border"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp">

                <ToggleButton
                    android:id="@+id/btnSentryMode"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:textOn="@string/legacy_sentry_on"
                    android:textOff="@string/legacy_sentry_off"
                    android:textSize="11sp"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/sentry_button_bg"/>

                <ToggleButton
                    android:id="@+id/btnVpn"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:textOn="@string/legacy_vpn_on"
                    android:textOff="@string/legacy_vpn_off"
                    android:textSize="11sp"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/sentry_button_bg"/>

                <ToggleButton
                    android:id="@+id/btnStreamMode"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:textOn="@string/legacy_stream_public"
                    android:textOff="@string/legacy_stream_private"
                    android:textSize="11sp"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/stream_mode_button_bg"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Stop Service Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStopDaemon"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/legacy_stop_service"
            android:textSize="12sp"
            app:backgroundTint="@color/status_danger"
            android:textColor="@color/white"
            app:cornerRadius="12dp"
            android:layout_marginBottom="12dp"/>

        <!-- Logs Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/bg_surface"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/card_border"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/legacy_logs_title"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp"/>

                <ScrollView
                    android:id="@+id/scrollLogs"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:background="@color/bg_base"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tvLogs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/legacy_logs_ready"
                        android:fontFamily="monospace"
                        android:textColor="@color/brand_primary"
                        android:textSize="11sp"/>
                </ScrollView>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
