<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/logsPanelRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_surface"
    android:orientation="vertical">

    <!-- Header with expand/collapse and controls -->
    <LinearLayout
        android:id="@+id/logsHeader"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/bg_elevated"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/btnExpandCollapse"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_expand_collapse"
            android:src="@drawable/ic_expand"
            app:tint="@color/brand_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/logs_panel_clipboard_emoji"
            android:textSize="14sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/logs_panel_title"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Filter Spinner -->
        <Spinner
            android:id="@+id/spinnerFilter"
            android:layout_width="100dp"
            android:layout_height="32dp"
            android:background="@drawable/spinner_background_glossy"
            android:popupBackground="@color/bg_surface" />

        <ImageButton
            android:id="@+id/btnClearLogs"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_clear_logs"
            android:src="@drawable/ic_clear"
            app:tint="@color/text_muted" />

    </LinearLayout>

    <!-- Logs RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerLogs"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="@color/bg_base"
        android:clipToPadding="false"
        android:padding="12dp"
        android:visibility="visible" />

</LinearLayout>
