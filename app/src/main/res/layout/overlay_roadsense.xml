<?xml version="1.0" encoding="utf-8"?>
<!--
  RoadSense floating overlay — cockpit-instrument HUD.

  ONE root, TWO states toggled by visibility (RoadSenseOverlayService swaps them):
    • pillRoot   — collapsed: calibration dot + compact "next hazard" readout.
    • cardRoot   — expanded: a luminous bearing GAUGE (radar ring + severity glow +
                   rotatable arrow) as the hero, a large distance readout, a zone/
                   severity caption, calibration signal, a segmented warn toggle, and
                   (when Calibration Mode fires) the confirm sub-panel.

  Design language: deep dark glass instrument surface, electric-cyan accent
  (#57C7FF), monospace telemetry, severity-tinted glow at runtime. Restraint over
  flash — a glanceable driving aid that still feels engineered.

  Tinted/rotated/animated at runtime by the service; static here.
  IDs consumed by RoadSenseOverlayService — keep stable.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/roadsenseRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- ============================ COLLAPSED PILL ============================ -->
    <LinearLayout
        android:id="@+id/pillRoot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/roadsense_pill_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="7dp"
        android:elevation="10dp">

        <!-- calibration signal dot (tinted green/orange/red at runtime) -->
        <ImageView
            android:id="@+id/pillCalDot"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/roadsense_cal_dot"
            android:contentDescription="@string/roadsense_cd_cal_level" />

        <TextView
            android:id="@+id/pillLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/roadsense_pill_scanning"
            android:textColor="#E6FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.01"
            android:maxLines="1"
            android:singleLine="true"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- ============================ EXPANDED CARD ============================ -->
    <LinearLayout
        android:id="@+id/cardRoot"
        android:layout_width="272dp"
        android:layout_height="wrap_content"
        android:background="@drawable/roadsense_card_bg"
        android:orientation="vertical"
        android:paddingHorizontal="18dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp"
        android:elevation="16dp"
        android:visibility="gone">

        <!-- grab handle / collapse affordance -->
        <View
            android:layout_width="34dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="10dp"
            android:background="@drawable/roadsense_pill_bg"
            android:alpha="0.5" />

        <!-- header: icon + title + calibration dot -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_roadsense"
                app:tint="#57C7FF"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/roadsense_title"
                android:textColor="#F2FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.10"
                android:textAllCaps="true" />

            <ImageView
                android:id="@+id/cardCalDot"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/roadsense_cal_dot"
                android:contentDescription="@string/roadsense_cd_cal_level" />

            <TextView
                android:id="@+id/cardCalLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="@string/roadsense_cal_learning"
                android:textColor="#99FFFFFF"
                android:textSize="9sp"
                android:fontFamily="monospace"
                android:textAllCaps="true"
                android:letterSpacing="0.06" />
        </LinearLayout>

        <!-- ===== HERO: bearing GAUGE + distance ===== -->
        <LinearLayout
            android:id="@+id/hazardRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- bearing gauge: severity glow (back) + radar ring + rotatable arrow -->
            <FrameLayout
                android:layout_width="92dp"
                android:layout_height="92dp">

                <ImageView
                    android:id="@+id/hazardGlow"
                    android:layout_width="84dp"
                    android:layout_height="84dp"
                    android:layout_gravity="center"
                    android:src="@drawable/roadsense_glow"
                    android:contentDescription="@null" />

                <ImageView
                    android:layout_width="92dp"
                    android:layout_height="92dp"
                    android:layout_gravity="center"
                    android:src="@drawable/roadsense_radar_ring"
                    android:contentDescription="@null" />

                <ImageView
                    android:id="@+id/hazardArrow"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_roadsense_arrow"
                    android:contentDescription="@string/roadsense_cd_direction" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:orientation="vertical">

                <!-- distance: big monospace number + unit -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom">

                    <TextView
                        android:id="@+id/hazardDistance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/roadsense_dash_distance"
                        android:textColor="#FFFFFFFF"
                        android:textSize="44sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:letterSpacing="-0.02"
                        android:includeFontPadding="false"
                        android:shadowColor="#8057C7FF"
                        android:shadowDx="0"
                        android:shadowDy="0"
                        android:shadowRadius="14" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginBottom="6dp"
                        android:text="@string/roadsense_unit_meters"
                        android:textColor="#99FFFFFF"
                        android:textSize="14sp"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <!-- severity / zone caption line -->
                <TextView
                    android:id="@+id/hazardSeverity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:text="@string/roadsense_clear_ahead"
                    android:textColor="#C2FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:textAllCaps="true"
                    android:letterSpacing="0.03"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:ellipsize="end" />
            </LinearLayout>
        </LinearLayout>

        <!-- etched divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/roadsense_divider" />

        <!-- ===== SEGMENTED WARN TOGGLE: audio / visual ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/roadsense_warn_label"
                android:textColor="#99FFFFFF"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:textAllCaps="true"
                android:letterSpacing="0.06" />

            <TextView
                android:id="@+id/toggleAudio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/roadsense_toggle_bg"
                android:paddingHorizontal="14dp"
                android:paddingVertical="7dp"
                android:text="@string/roadsense_toggle_audio"
                android:textColor="#E6FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.03"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/toggleVisual"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/roadsense_toggle_bg"
                android:paddingHorizontal="14dp"
                android:paddingVertical="7dp"
                android:text="@string/roadsense_toggle_visual"
                android:textColor="#E6FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.03"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- ===== CALIBRATION-MODE CONFIRM SUB-PANEL (R-OVL-6, shown only when
             a pending confirm exists) ===== -->
        <LinearLayout
            android:id="@+id/confirmPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical"
            android:padding="14dp"
            android:background="@drawable/roadsense_confirm_bg"
            android:visibility="gone">

            <TextView
                android:id="@+id/confirmPrompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/roadsense_confirm_prompt"
                android:textColor="#F2FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.03" />

            <!-- algo's pre-filled assessment -->
            <TextView
                android:id="@+id/confirmAssessment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="@string/roadsense_dash_distance"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <!-- Severity correction (R-OVL-6): pre-selected to the algo bucket; the
                 user can adjust before Confirm. -->
            <LinearLayout
                android:id="@+id/confirmSeverityRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/confirmSevMinor"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:gravity="center"
                    android:background="@drawable/roadsense_toggle_bg"
                    android:paddingVertical="7dp"
                    android:text="@string/roadsense_sev_minor"
                    android:textColor="#E6FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:clickable="true"
                    android:focusable="true" />
                <TextView
                    android:id="@+id/confirmSevModerate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:gravity="center"
                    android:background="@drawable/roadsense_toggle_bg"
                    android:paddingVertical="7dp"
                    android:text="@string/roadsense_sev_moderate"
                    android:textColor="#E6FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:clickable="true"
                    android:focusable="true" />
                <TextView
                    android:id="@+id/confirmSevSevere"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:gravity="center"
                    android:background="@drawable/roadsense_toggle_bg"
                    android:paddingVertical="7dp"
                    android:text="@string/roadsense_sev_severe"
                    android:textColor="#E6FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Type correction (R-OVL-6): breaker vs pothole. -->
            <LinearLayout
                android:id="@+id/confirmTypeRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/confirmTypeBreaker"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:gravity="center"
                    android:background="@drawable/roadsense_toggle_bg"
                    android:paddingVertical="7dp"
                    android:text="@string/roadsense_type_breaker"
                    android:textColor="#E6FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:clickable="true"
                    android:focusable="true" />
                <TextView
                    android:id="@+id/confirmTypePothole"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:gravity="center"
                    android:background="@drawable/roadsense_toggle_bg"
                    android:paddingVertical="7dp"
                    android:text="@string/roadsense_type_pothole"
                    android:textColor="#E6FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/confirmReject"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    android:gravity="center"
                    android:background="@drawable/roadsense_btn_ghost"
                    android:paddingVertical="9dp"
                    android:text="@string/roadsense_confirm_reject"
                    android:textColor="#FFB4AB"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.03"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/confirmAccept"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    android:gravity="center"
                    android:background="@drawable/roadsense_btn_accent"
                    android:paddingVertical="9dp"
                    android:text="@string/roadsense_confirm_accept"
                    android:textColor="#C7FFD9"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.03"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
