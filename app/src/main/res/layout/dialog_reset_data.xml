<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@color/bg_surface">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_delete"
                android:contentDescription="@string/cd_reset"
                app:tint="@color/status_error" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/reset_title"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/reset_subtitle"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Warning banner -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/bg_elevated"
            app:cardCornerRadius="10dp"
            app:strokeColor="@color/status_error"
            app:strokeWidth="1dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/reset_warning"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:padding="12dp" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Category checkboxes -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbResetTrips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reset_cat_trips"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reset_cat_trips_desc"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbResetSocHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reset_cat_soc_history"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reset_cat_soc_history_desc"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbResetSoh"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reset_cat_soh"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reset_cat_soh_desc"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbResetAbrpToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reset_cat_abrp_token"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reset_cat_abrp_token_desc"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbResetBydCloud"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reset_cat_byd_cloud"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reset_cat_byd_cloud_desc"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbResetMediaRecordings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reset_cat_recordings"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reset_cat_recordings_desc"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbResetMediaSurveillance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reset_cat_sentry_events"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reset_cat_sentry_events_desc"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbResetMediaProximity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reset_cat_proximity"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reset_cat_proximity_desc"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbResetMediaTrips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reset_cat_trip_files"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reset_cat_trip_files_desc"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="14dp" />

        <!-- Quick toggle row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResetSelectAll"
                style="@style/Widget.Overdrive.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/action_select_all"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResetClearAll"
                style="@style/Widget.Overdrive.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/action_clear_plain"
                android:layout_marginStart="8dp"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
