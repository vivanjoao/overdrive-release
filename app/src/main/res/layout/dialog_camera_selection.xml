<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/bg_surface">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_camera_select"
            android:contentDescription="@string/cd_camera"
            app:tint="@color/brand_primary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/camera_selection_title"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tvCameraSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/camera_selection_subtitle"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Current status card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/bg_elevated"
        app:cardCornerRadius="12dp"
        app:strokeColor="@color/card_border"
        app:strokeWidth="1dp"
        app:cardElevation="0dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <View
                android:id="@+id/dotCameraStatus"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/status_dot_online" />

            <TextView
                android:id="@+id/tvCurrentCamera"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="@string/camera_current_auto"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Camera options -->
    <RadioGroup
        android:id="@+id/rgCameraOptions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/rbCameraAuto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/camera_option_auto"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:buttonTint="@color/brand_primary" />

        <RadioButton
            android:id="@+id/rbCamera0"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/camera_option_0"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:buttonTint="@color/brand_primary" />

        <RadioButton
            android:id="@+id/rbCamera1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/camera_option_1"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:buttonTint="@color/brand_primary" />

        <RadioButton
            android:id="@+id/rbCamera2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/camera_option_2"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:buttonTint="@color/brand_primary" />

        <RadioButton
            android:id="@+id/rbCamera3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/camera_option_3"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:buttonTint="@color/brand_primary" />

        <RadioButton
            android:id="@+id/rbCamera4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/camera_option_4"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:buttonTint="@color/brand_primary" />

        <RadioButton
            android:id="@+id/rbCamera5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/camera_option_5"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:buttonTint="@color/brand_primary" />
    </RadioGroup>

    <!-- Hint text -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/camera_selection_hint"
        android:textColor="@color/text_muted"
        android:textSize="11sp" />

</LinearLayout>
</ScrollView>
