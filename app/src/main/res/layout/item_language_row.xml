<?xml version="1.0" encoding="utf-8"?>
<!-- Single row in the language picker. Native-script name on the left,
     BCP-47 tag on the right, optional check mark for the current pick. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/languageRow"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="20dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvLangName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            tools:text="日本語" />

        <TextView
            android:id="@+id/tvLangSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:visibility="gone"
            tools:text="Auto"
            tools:visibility="visible" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvLangTag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:fontFamily="monospace"
        android:textColor="@color/text_muted"
        android:textSize="11sp"
        tools:text="ja" />

    <ImageView
        android:id="@+id/ivLangCheck"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_check"
        android:visibility="invisible"
        tools:visibility="visible" />

</LinearLayout>
