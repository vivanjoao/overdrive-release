<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base"
    android:orientation="vertical">

    <!-- Ultra Compact Calendar Header (item 7: now collapsible) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp">

        <ImageButton
            android:id="@+id/btnPrevMonth"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_previous_month"
            android:src="@drawable/ic_chevron_left"
            app:tint="@color/text_secondary" />

        <TextView
            android:id="@+id/tvCurrentMonth"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            tools:text="January 2026" />

        <ImageButton
            android:id="@+id/btnNextMonth"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_next_month"
            android:src="@drawable/ic_chevron_right"
            app:tint="@color/text_secondary" />

        <!-- Expand/collapse the full month grid. Week strip below stays
             visible regardless. -->
        <ImageButton
            android:id="@+id/btnCalendarCollapse"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_toggle_full_month"
            android:src="@drawable/ic_chevron_left"
            android:rotation="270"
            app:tint="@color/text_secondary" />
    </LinearLayout>

    <!-- Always-visible week strip: 7 days centered on the selected date. Arrow
         buttons advance the strip by ±7 days without expanding the month grid.
         Replaces the previous "expand-or-nothing" calendar UX. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="4dp"
        android:paddingBottom="4dp">

        <ImageButton
            android:id="@+id/btnPrevWeek"
            android:layout_width="32dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_previous_week"
            android:src="@drawable/ic_chevron_left"
            app:tint="@color/text_secondary" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerWeekStrip"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:overScrollMode="never"
            android:nestedScrollingEnabled="false" />

        <ImageButton
            android:id="@+id/btnNextWeek"
            android:layout_width="32dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_next_week"
            android:src="@drawable/ic_chevron_right"
            app:tint="@color/text_secondary" />
    </LinearLayout>

    <!-- Full-month grid body — collapsed by default (visibility="gone"), expanded
         via the chevron in the month header. The week strip above is always
         visible so day-by-day navigation works without expanding the month.
         The XML default of `gone` matches the runtime default applied in
         initViews(); this keeps the Android Studio preview from showing two
         stacked calendars (week strip + month grid). -->
    <LinearLayout
        android:id="@+id/calendarBody"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        tools:visibility="visible">

    <!-- Compact Day Headers -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/day_initial_sunday"
            android:textColor="@color/text_muted"
            android:textSize="10sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/day_initial_monday"
            android:textColor="@color/text_muted"
            android:textSize="10sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/day_initial_tuesday"
            android:textColor="@color/text_muted"
            android:textSize="10sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/day_initial_wednesday"
            android:textColor="@color/text_muted"
            android:textSize="10sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/day_initial_thursday"
            android:textColor="@color/text_muted"
            android:textSize="10sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/day_initial_friday"
            android:textColor="@color/text_muted"
            android:textSize="10sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/day_initial_saturday"
            android:textColor="@color/text_muted"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Ultra Compact Calendar Grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCalendar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="4dp"
        android:overScrollMode="never"
        android:nestedScrollingEnabled="false" />

    </LinearLayout>
    <!-- /calendarBody -->

    <!-- Professional Filter Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:background="@color/bg_surface">

        <TextView
            android:id="@+id/tvSelectedDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            tools:text="Jan 20" />

        <View
            android:layout_width="1dp"
            android:layout_height="16dp"
            android:layout_marginHorizontal="12dp"
            android:background="@color/divider" />

        <!-- Professional Segmented Filter -->
        <com.google.android.material.chip.ChipGroup
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:singleSelection="true"
            app:chipSpacingHorizontal="4dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/btnFilterAll"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:text="@string/recording_lib_filter_all"
                android:checked="true"
                android:textSize="11sp"
                app:chipBackgroundColor="@color/chip_background"
                app:chipStrokeWidth="0dp"
                app:chipCornerRadius="13dp"
                app:chipMinHeight="26dp"
                app:chipMinTouchTargetSize="26dp"
                android:textColor="@color/chip_text"
                app:checkedIconVisible="false" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnFilterNormal"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:text="@string/recording_lib_filter_rec"
                android:textSize="11sp"
                app:chipBackgroundColor="@color/chip_background"
                app:chipStrokeWidth="0dp"
                app:chipCornerRadius="13dp"
                app:chipMinHeight="26dp"
                app:chipMinTouchTargetSize="26dp"
                android:textColor="@color/chip_text"
                app:checkedIconVisible="false" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnFilterSentry"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:text="@string/recording_lib_filter_sentry"
                android:textSize="11sp"
                app:chipBackgroundColor="@color/chip_background"
                app:chipStrokeWidth="0dp"
                app:chipCornerRadius="13dp"
                app:chipMinHeight="26dp"
                app:chipMinTouchTargetSize="26dp"
                android:textColor="@color/chip_text"
                app:checkedIconVisible="false" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnFilterProximity"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:text="@string/recording_lib_filter_prox"
                android:textSize="11sp"
                app:chipBackgroundColor="@color/chip_background"
                app:chipStrokeWidth="0dp"
                app:chipCornerRadius="13dp"
                app:chipMinHeight="26dp"
                app:chipMinTouchTargetSize="26dp"
                android:textColor="@color/chip_text"
                app:checkedIconVisible="false" />

        </com.google.android.material.chip.ChipGroup>
    </LinearLayout>

    <!--
      v3 filter rows (item 7).
      Two semantically-distinct dimensions get two rows so the user can scan
      them independently. Each row has a small "What:" / "Severity:" label
      anchoring it, and its own "Any" chip to clear *that row only*.
    -->

    <!-- Row 2: WHAT (actor class) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingTop="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/recording_lib_filter_what"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginEnd="8dp" />

        <HorizontalScrollView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/actorChipGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:chipSpacingHorizontal="4dp"
                app:singleLine="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipActorAny"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:text="@string/recording_lib_chip_any"
                    android:checked="true"
                    android:textSize="11sp"
                    app:chipMinHeight="26dp"
                    app:chipMinTouchTargetSize="26dp" />
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipActorPerson"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:text="@string/recording_lib_chip_person"
                    android:textSize="11sp"
                    app:chipMinHeight="26dp"
                    app:chipMinTouchTargetSize="26dp" />
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipActorVehicle"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:text="@string/recording_lib_chip_vehicle"
                    android:textSize="11sp"
                    app:chipMinHeight="26dp"
                    app:chipMinTouchTargetSize="26dp" />
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipActorBike"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:text="@string/recording_lib_chip_bike"
                    android:textSize="11sp"
                    app:chipMinHeight="26dp"
                    app:chipMinTouchTargetSize="26dp" />
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipActorAnimal"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:text="@string/recording_lib_chip_animal"
                    android:textSize="11sp"
                    app:chipMinHeight="26dp"
                    app:chipMinTouchTargetSize="26dp" />

            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Row 3: SEVERITY -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/recording_lib_filter_severity"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginEnd="8dp" />

        <HorizontalScrollView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/severityChipGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:chipSpacingHorizontal="4dp"
                app:singleLine="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSevAny"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:text="@string/recording_lib_chip_any"
                    android:checked="true"
                    android:textSize="11sp"
                    app:chipMinHeight="26dp"
                    app:chipMinTouchTargetSize="26dp" />
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSevAlert"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:text="@string/recording_lib_chip_alert"
                    android:textSize="11sp"
                    app:chipMinHeight="26dp"
                    app:chipMinTouchTargetSize="26dp" />
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSevCritical"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:text="@string/recording_lib_chip_critical"
                    android:textSize="11sp"
                    app:chipMinHeight="26dp"
                    app:chipMinTouchTargetSize="26dp" />

            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- Multi-Select Toolbar (hidden by default) -->
    <LinearLayout
        android:id="@+id/selectToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:background="@color/bg_elevated"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvSelectedCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/brand_primary"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:text="@string/recording_lib_selected_count_zero" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelectAll"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/action_select_all_short"
            android:textSize="12sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeleteSelected"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/action_delete"
            android:textSize="12sp"
            android:textColor="@color/status_danger"
            app:icon="@drawable/ic_delete"
            app:iconTint="@color/status_danger"
            app:iconSize="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelSelect"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/action_cancel"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Recordings List (takes remaining space) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerRecordings"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="16dp" />

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/emptyStateContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/recording_lib_empty_emoji"
                android:textSize="32sp" />

            <TextView
                android:id="@+id/tvEmptyState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/recording_lib_no_recordings"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
