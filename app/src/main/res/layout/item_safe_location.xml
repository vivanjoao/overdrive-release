<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/bg_elevated"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/card_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Top row: Name + Toggle + Delete -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvZoneName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/safe_loc_default_name"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tvZoneRadius"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/safe_loc_default_radius"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchZoneEnabled"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <ImageButton
                android:id="@+id/btnDeleteZone"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_delete"
                android:contentDescription="@string/cd_delete_zone"
                app:tint="@color/text_muted" />

        </LinearLayout>

        <!-- Coordinates -->
        <TextView
            android:id="@+id/tvZoneCoords"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/safe_loc_default_coords"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:layout_marginTop="4dp" />

        <!-- Radius Slider -->
        <com.google.android.material.slider.Slider
            android:id="@+id/sliderZoneRadius"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:valueFrom="50"
            android:valueTo="500"
            android:stepSize="10" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/safe_loc_min_radius"
                android:textColor="@color/text_muted"
                android:textSize="10sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/safe_loc_max_radius"
                android:textColor="@color/text_muted"
                android:textSize="10sp" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
