<?xml version="1.0" encoding="utf-8"?>
<!-- First-launch setup guide dialog.
     Wrapped in ScrollView so the content + buttons are always reachable
     on landscape BYD head units (720p, ~604dp usable height). -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_surface"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Version banner (shown only after an update, hidden on first install) -->
    <TextView
        android:id="@+id/tvVersionBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="@drawable/overlay_pill_background"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:textColor="@color/brand_primary"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone"
        tools:text="🔄 Updated to v11.0 — re-confirm autostart" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/setup_guide_title"
        android:textColor="@color/brand_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/setup_guide_subtitle"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <!-- Step 1: Language -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/overlay_expanded_background"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/overlay_pill_background"
                android:gravity="center"
                android:text="@string/setup_step_one_label"
                android:textColor="@color/brand_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setup_language_title"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/setup_language_body"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />

            </LinearLayout>

            <ImageView
                android:id="@+id/ivLanguageCheck"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_check"
                android:visibility="visible"
                android:contentDescription="@string/cd_step_completed" />

        </LinearLayout>

        <TextView
            android:id="@+id/btnOpenLanguage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/overlay_action_button_bg"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:text="@string/setup_language_button"
            android:textColor="@color/brand_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Step 2: Auto-start -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/overlay_expanded_background"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/overlay_pill_background"
                android:gravity="center"
                android:text="@string/setup_step_two_label"
                android:textColor="@color/brand_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setup_autostart_title"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/setup_autostart_body"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />

            </LinearLayout>

            <ImageView
                android:id="@+id/ivAutoStartCheck"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_check"
                android:visibility="invisible"
                android:contentDescription="@string/cd_step_completed" />

        </LinearLayout>

        <TextView
            android:id="@+id/btnOpenAutoStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/overlay_action_button_bg"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:text="@string/setup_autostart_button"
            android:textColor="@color/brand_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Step 3: Overlay Permission -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/overlay_expanded_background"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/overlay_pill_background"
                android:gravity="center"
                android:text="@string/setup_step_three_label"
                android:textColor="@color/brand_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setup_overlay_title"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/setup_overlay_body"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />

            </LinearLayout>

            <ImageView
                android:id="@+id/ivOverlayCheck"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_check"
                android:visibility="invisible"
                android:contentDescription="@string/cd_permission_granted" />

        </LinearLayout>

        <TextView
            android:id="@+id/btnOpenOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/overlay_action_button_bg"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:text="@string/setup_overlay_button"
            android:textColor="@color/brand_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Action buttons — always visible, high contrast.
         Skip button takes flex space and ellipsizes on narrow dialogs;
         Done button has fixed width so its label can never be clipped. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="end|center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnSkip"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:singleLine="true"
            android:ellipsize="end"
            android:paddingHorizontal="20dp"
            android:text="@string/action_remind_me_later"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="?android:attr/selectableItemBackground" />

        <TextView
            android:id="@+id/btnDone"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:minWidth="96dp"
            android:gravity="center"
            android:singleLine="true"
            android:includeFontPadding="false"
            android:paddingHorizontal="24dp"
            android:background="@color/brand_primary"
            android:text="@string/action_done"
            android:textColor="#000000"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
</ScrollView>
