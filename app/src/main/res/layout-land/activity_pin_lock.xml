<?xml version="1.0" encoding="utf-8"?>
<!--
  Landscape variant of the PIN lock screen. Designed for the BYD Seal
  15.6" panel (1920×1080 = ~960dp×540dp).

  Composition:
    LEFT  ~50% : header glyph + title + subtitle + dot row
    RIGHT ~50% : 4×3 numeric keypad

  Same widget IDs as portrait so PinLockActivity logic is layout-agnostic.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="48dp">

    <!-- LEFT pane: identity + dots -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_pin_glyph_circle">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_security_lock"
                app:tint="?attr/colorOnPrimaryContainer" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvPinTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:accessibilityHeading="true"
            android:gravity="center"
            android:text="@string/pin_lock_title"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPinSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="32dp"
            android:accessibilityLiveRegion="polite"
            android:gravity="center"
            android:minLines="2"
            android:text="@string/pin_lock_subtitle_default"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <LinearLayout
            android:id="@+id/pinDotRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:accessibilityLiveRegion="polite"
            android:gravity="center"
            android:orientation="horizontal">

            <View
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginHorizontal="7dp"
                android:background="@drawable/pin_dot_empty" />

            <View
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginHorizontal="7dp"
                android:background="@drawable/pin_dot_empty" />

            <View
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginHorizontal="7dp"
                android:background="@drawable/pin_dot_empty" />

            <View
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginHorizontal="7dp"
                android:background="@drawable/pin_dot_empty" />

            <View
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginHorizontal="7dp"
                android:background="@drawable/pin_dot_empty" />

            <View
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginHorizontal="7dp"
                android:background="@drawable/pin_dot_empty" />

            <View
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginHorizontal="7dp"
                android:background="@drawable/pin_dot_empty" />

            <View
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginHorizontal="7dp"
                android:background="@drawable/pin_dot_empty" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvPinRecoveryHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:alpha="0.7"
            android:fontFamily="monospace"
            android:gravity="center"
            android:importantForAccessibility="no"
            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
            android:textColor="?attr/colorOnSurfaceVariant" />
    </LinearLayout>

    <!-- RIGHT pane: keypad -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1">

        <GridLayout
            android:id="@+id/pinKeypadGrid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:columnCount="3"
            android:rowCount="4">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPin1"
                style="@style/Widget.Overdrive.M3.PinKey"
                android:layout_row="0"
                android:layout_column="0"
                android:text="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPin2"
                style="@style/Widget.Overdrive.M3.PinKey"
                android:layout_row="0"
                android:layout_column="1"
                android:text="2" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPin3"
                style="@style/Widget.Overdrive.M3.PinKey"
                android:layout_row="0"
                android:layout_column="2"
                android:text="3" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPin4"
                style="@style/Widget.Overdrive.M3.PinKey"
                android:layout_row="1"
                android:layout_column="0"
                android:text="4" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPin5"
                style="@style/Widget.Overdrive.M3.PinKey"
                android:layout_row="1"
                android:layout_column="1"
                android:text="5" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPin6"
                style="@style/Widget.Overdrive.M3.PinKey"
                android:layout_row="1"
                android:layout_column="2"
                android:text="6" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPin7"
                style="@style/Widget.Overdrive.M3.PinKey"
                android:layout_row="2"
                android:layout_column="0"
                android:text="7" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPin8"
                style="@style/Widget.Overdrive.M3.PinKey"
                android:layout_row="2"
                android:layout_column="1"
                android:text="8" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPin9"
                style="@style/Widget.Overdrive.M3.PinKey"
                android:layout_row="2"
                android:layout_column="2"
                android:text="9" />

            <Space
                android:layout_row="3"
                android:layout_column="0"
                android:layout_width="@dimen/pin_key_size"
                android:layout_height="@dimen/pin_key_size"
                android:layout_margin="@dimen/pin_key_margin" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPin0"
                style="@style/Widget.Overdrive.M3.PinKey"
                android:layout_row="3"
                android:layout_column="1"
                android:text="0" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPinBackspace"
                style="@style/Widget.Overdrive.M3.PinKey.Action"
                android:layout_row="3"
                android:layout_column="2"
                android:contentDescription="@string/pin_lock_backspace_cd"
                app:icon="@drawable/ic_pin_backspace" />
        </GridLayout>
    </FrameLayout>
</LinearLayout>
