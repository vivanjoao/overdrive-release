<?xml version="1.0" encoding="utf-8"?>
<!--
  Canonical Overdrive dimension tokens.

  Centralizing card / tile dimensions here so every fragment renders with
  identical rhythm regardless of which session shipped it. Layouts MUST
  reference these tokens instead of hard-coded `dp` values for any
  page-padding, card radius, card padding, inter-card gap, grid tile sizing,
  card icon size, or section overline spacing.

  Target device: BYD Seal 15.6" rotatable infotainment.
    Landscape  1920x1080  (960dp x 540dp)
    Portrait   1080x1920  (540dp x 960dp)

  Material 3 1.13.0.
-->
<resources>
    <!-- Page padding / outer rhythm -->
    <dimen name="page_padding_horizontal">24dp</dimen>
    <dimen name="page_padding_top">20dp</dimen>
    <dimen name="page_padding_bottom">24dp</dimen>

    <!-- Inter-card gaps -->
    <dimen name="card_gap_vertical">12dp</dimen>
    <dimen name="card_gap_horizontal">12dp</dimen>      <!-- total — split as 6dp/6dp on each side -->
    <dimen name="card_gap_horizontal_half">6dp</dimen>   <!-- per-side margin in horizontal grids -->

    <!-- Card radii -->
    <dimen name="card_radius_standard">20dp</dimen>     <!-- Dashboard metrics, Diagnostics tiles, Integrations cards, Settings sections -->
    <dimen name="card_radius_hero">24dp</dimen>         <!-- Dashboard hero, Recordings preview pane -->
    <dimen name="card_radius_dialog">28dp</dimen>       <!-- M3 dialog spec; already wired via theme -->
    <dimen name="card_radius_accent">14dp</dimen>       <!-- pills inside cards, segmented-button corners -->

    <!-- Card padding -->
    <dimen name="card_padding_standard">20dp</dimen>
    <dimen name="card_padding_hero">24dp</dimen>

    <!-- Grid tile sizing -->
    <dimen name="grid_tile_min_height">128dp</dimen>

    <!-- Card icon sizes -->
    <dimen name="card_icon_standard">24dp</dimen>
    <dimen name="card_icon_service">32dp</dimen>
    <dimen name="card_icon_hero">56dp</dimen>

    <!-- Section overline gap -->
    <dimen name="section_overline_top">12dp</dimen>
    <dimen name="section_overline_bottom">8dp</dimen>

    <!-- PIN unlock keypad (PinLockActivity). 72dp keys give a 14.4mm hit
         target on the BYD Seal 15.6" panel — well above Material's 48dp
         minimum and comfortable for cluster-distance interaction. -->
    <dimen name="pin_key_size">72dp</dimen>
    <dimen name="pin_key_margin">6dp</dimen>
    <dimen name="pin_key_corner">36dp</dimen>
    <dimen name="pin_key_text_size">28sp</dimen>
</resources>
