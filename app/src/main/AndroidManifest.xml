    <!-- Additional BYD permissions -->
    <uses-permission android:name="android.permission.BYDAUTO_SECURITY_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_COLLISION_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_COLLISION_SET" />
    <uses-permission android:name="android.permission.BYDAUTO_LOCATION_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_LOCATION_SET" />
    <uses-permission android:name="android.permission.BYDAUTO_VIDEO_GET" />
