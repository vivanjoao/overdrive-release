    <uses-permission android:name="android.permission.BYDAUTO_RADIO_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_RADIO_SET" />
    <uses-permission android:name="android.permission.BYDAUTO_SPECIAL_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_SPECIAL_SET" />
    <uses-permission android:name="android.permission.BYDAUTO_REMINDER_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_REMINDER_SET" />
    <uses-permission android:name="android.permission.BYDAUTO_VERSION_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_VERSION_SET" />
    <uses-permission android:name="android.permission.BYDAUTO_FUNCNOTICE_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_FUNCNOTICE_SET" />
    <uses-permission android:name="android.permission.BYDAUTO_PHONE_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_PHONE_SET" />
    <uses-permission android:name="android.permission.BYDAUTO_MOTOR_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_MOTOR_SET" />
