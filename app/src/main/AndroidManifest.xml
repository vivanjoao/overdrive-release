    <uses-permission android:name="android.permission.BYDAUTO_RESCUE_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_RESCUE_SET" />
    <uses-permission android:name="android.permission.BYDAUTO_TEST_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_TEST_SET" />
    <uses-permission android:name="android.permission.BYDAUTO_DTC_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_DTC_SET" />
    <uses-permission android:name="android.permission.BYDAUTO_BIGDATA_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_YUN_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_GB_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_RSE_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_RSE_SET" />
    <uses-permission android:name="android.permission.BYDAUTO_MQTT_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_MQTT_SET" />
    <!-- BYD Camera and data acquisition -->
    <uses-permission android:name="android.permission.BYD_CAMERA" />
    <uses-permission android:name="android.permission.BYDACQUISITION_SEND_BUFFER" />
    <uses-permission android:name="android.permission.BYDACQUISITION_SEND_FILE" />
    <uses-permission android:name="android.permission.BYDDIAGNOSTIC_SEND_BUFFER" />
    <!-- Generic BYD -->
    <uses-permission android:name="android.permission.BYD" />
    <uses-permission android:name="android.permission.DEVICE_ACC" />
    <uses-permission android:name="android.permission.DEVICE_POWER" />

    <!-- DiCarServer ContentProvider — local property bus.
         protectionLevel=normal, auto-granted on install. The provider
         exposes read/write to ICarPropertyService over Binder. We can
         query non-sigperm properties; signature-protected writes
         (BYDAUTO_BODYWORK_SET et al) will be denied by DiCarServer
         since our APK isn't signed with the BYD platform key. -->
    <uses-permission android:name="com.byd.car.server.PROVIDER" />
    <!-- Data cache (for ACC whitelist) -->
    <uses-permission android:name="android.permission.ACCESS_APPOPSDATA" />
    
    <!-- Overlay permission for floating status indicator (user must grant manually) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application
        android:name="com.overdrive.app.OverdriveApplication"
        android:allowBackup="true"
        android:label="@string/app_name"
        android:extractNativeLibs="true"
        android:theme="@style/Theme.Overdrive.M3"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:persistent="true"
        android:requestLegacyExternalStorage="true"
        android:usesCleartextTraffic="true">

        <!-- New Modern UI Activity -->
        <activity 
            android:name="com.overdrive.app.ui.MainActivity"
            android:exported="true"
            android:screenOrientation="unspecified"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.overdrive.app.START_LOCATION_ACTIVITY" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>



        <!-- PIN Lock Activity. Gates MainActivity only — never the cam
             daemon, AccSentry, surveillance, recording, Telegram alerts,
             the status overlay service, the Blocker, or the Deterrent.
             In MainActivity's task (singleTop) so unlock returns straight
             to the user's nav destination. excludeFromRecents keeps the
             keypad off the recents stack. -->
        <activity
            android:name="com.overdrive.app.ui.PinLockActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:excludeFromRecents="true"
            android:screenOrientation="unspecified"
            android:configChanges="keyboardHidden"
            android:theme="@style/Theme.Overdrive.M3" />

        <!-- Blocker Activity for Sentry Mode (transparent click blocker) -->
        <activity
            android:name="com.overdrive.app.BlockerActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar.Fullscreen"
            android:excludeFromRecents="true"
            android:launchMode="singleInstance"
            android:screenOrientation="unspecified"
            android:configChanges="orientation|screenSize|keyboardHidden" />

        <!-- Screen Deterrent: fullscreen warning shown on motion while ACC off.
             Launched via `am start` from byd_cam_daemon (UID 2000) AFTER the
             daemon wakes the panel via PowerManager.TurnBacklightOn. Uses
             singleInstance so repeat launches during sustained motion are
             coalesced (Activity already running just bumps onNewIntent / stays
             up while the deadline keeps extending). -->
        <activity
            android:name="com.overdrive.app.DeterrentActivity"
            android:exported="true"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen"
            android:excludeFromRecents="true"
            android:launchMode="singleInstance"
            android:screenOrientation="unspecified"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboardHidden|navigation|fontScale|locale|layoutDirection|uiMode|density"
            android:showOnLockScreen="true"
            android:turnScreenOn="true" />

        <!-- Location Starter Activity - Transparent, starts Location service and finishes immediately -->
        <!-- Used by SentryDaemon to restart Location service without bringing app to foreground -->
        <activity
            android:name="com.overdrive.app.ui.LocationStarterActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:taskAffinity=""
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="com.overdrive.app.START_LOCATION_SILENT" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <receiver
            android:name="com.overdrive.app.receiver.BootReceiver"
            android:enabled="true"
            android:exported="true"
            android:directBootAware="true">
            <intent-filter android:priority="1000">
                <!-- Standard boot -->
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <!-- Screen/power events for ACC mode wake -->
                <action android:name="android.intent.action.SCREEN_ON" />
                <action android:name="android.intent.action.USER_PRESENT" />
                <action android:name="android.intent.action.USER_UNLOCKED" />
                <!-- Power connection events -->
                <action android:name="android.intent.action.ACTION_POWER_CONNECTED" />
                <action android:name="android.intent.action.ACTION_POWER_DISCONNECTED" />
                <!-- BYD-specific ACC mode events -->
                <action android:name="com.byd.action.ACC_ON" />
                <action android:name="com.byd.action.ACC_OFF" />
                <action android:name="com.byd.action.IGN_ON" />
                <action android:name="com.byd.accmode.ACC_MODE_CHANGED" />
                <!-- Network state changes (WiFi reconnect) -->
                <action android:name="android.net.wifi.STATE_CHANGE" />
                <action android:name="android.net.conn.CONNECTIVITY_CHANGE" />
            </intent-filter>
        </receiver>

        <!-- Process Revival Receiver - AlarmManager-driven watchdog that revives
             the process if it has been killed (force-stop, OOM, OEM cleanup).
             No intent-filter: only invoked via explicit PendingIntent. -->
        <receiver
            android:name="com.overdrive.app.receiver.ProcessRevivalReceiver"
            android:enabled="true"
            android:exported="false"
            android:directBootAware="true" />

        <!-- Location Boot Receiver - Auto-start Location service after device reboot -->
        <receiver
            android:name="com.overdrive.app.receiver.LocationBootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>


        <!-- Location Sidecar Service - Writes GPS to shared file for daemon -->
        <service
            android:name="com.overdrive.app.services.LocationSidecarService"
            android:foregroundServiceType="location|dataSync"
            android:exported="true" />

        <!-- Daemon Keepalive Service - Keeps app alive and monitors SCREEN_OFF -->
        <service
            android:name="com.overdrive.app.services.DaemonKeepaliveService"
            android:foregroundServiceType="specialUse|dataSync"
            android:exported="false" />

        <!-- RoadSense IMU Sidecar - the ONLY app-side RoadSense component (D-023).
             Acquires -iner accel+gyro at ~100 Hz and batches them to the daemon
             IPC (port 19877) as IMU_BATCH frames. Daemon owns its lifecycle and
             drives rate via the EXTRA_RATE hint (D-021). Started by the daemon,
             not exported. -->
        <!-- exported=true so the CameraDaemon (shell uid, synthetic context, can't
             startForegroundService cross-process) can launch it via
             `am start-foreground-service` — the same proven path GpsMonitor uses for
             LocationSidecarService. -->
        <service
            android:name="com.overdrive.app.roadsense.sidecar.RoadSenseImuSidecarService"
            android:foregroundServiceType="dataSync"
            android:exported="true" />

        <!-- RoadSense floating overlay (app-side renderer, D-024). Reads
             daemon-published roadSense.overlayState from UCM and draws the
             pill/card. specialUse FGS like StatusOverlayService. -->
        <service
            android:name="com.overdrive.app.roadsense.overlay.RoadSenseOverlayService"
            android:foregroundServiceType="specialUse"
            android:exported="false" />

        <!-- Status Overlay Service - Floating recording/trip status indicator -->
        <service
            android:name="com.overdrive.app.overlay.StatusOverlayService"
            android:foregroundServiceType="specialUse"
            android:exported="false" />

        <!-- AccessibilityService Keep-Alive - Highest process priority protection.
             Prevents BYD firmware from killing the app after 24 hours.
             Enable via: settings put secure enabled_accessibility_services com.overdrive.app/com.overdrive.app.services.KeepAliveAccessibilityService
                         settings put secure accessibility_enabled 1 -->
        <service
            android:name="com.overdrive.app.services.KeepAliveAccessibilityService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="false">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- FileProvider for sharing video files -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>
</manifest>
